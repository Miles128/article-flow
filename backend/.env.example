SECRET_KEY=your-secret-key-here

# LLM API 配置（必填，推荐 DeepSeek）
LLM_API_KEY=sk-your-deepseek-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL_NAME=deepseek-v4-flash
LLM_TEMPERATURE=0.7

# OpenAI 示例（若用 OpenAI 代理则改 base_url）
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL_NAME=gpt-4o-mini

# Tavily 搜索 API Key（热搜选题用，可选，免费注册：https://app.tavily.com）
TAVILY_API_KEY=tvly-your-key-here

CORS_ORIGINS=http://localhost:3000

# 可选：运行时数据目录（默认 backend/data）
# ARTICLE_FLOW_DATA_DIR=

# 安全：默认关闭无鉴权通用 AI 代理 / 局域网监听
# ARTICLE_FLOW_ALLOW_AI_PROXY=0
# ARTICLE_FLOW_ALLOW_LAN=0
# FLASK_HOST=127.0.0.1